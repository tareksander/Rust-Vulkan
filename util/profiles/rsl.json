{
    "$schema": "https://schema.khronos.org/vulkan/profiles-0.8-latest.json#",
    "capabilities": {
        "base": {
            "extensions": {
                "VK_KHR_maintenance7": 1,
                "VK_KHR_maintenance8": 1,
                "VK_KHR_maintenance9": 1,
                "VK_KHR_pipeline_binary": 1,
                "VK_KHR_shader_maximal_reconvergence": 1,
                "VK_EXT_device_generated_commands": 1
            },
            "features": {
                "VkPhysicalDeviceFeatures": {
                    "shaderInt16": true,
                    "shaderSampledImageArrayDynamicIndexing": true,
                    "shaderStorageImageArrayDynamicIndexing": true,
                    "shaderStorageBufferArrayDynamicIndexing": true,
                    "shaderUniformBufferArrayDynamicIndexing": true,
                    "fragmentStoresAndAtomics": true,
                    "multiDrawIndirect": true
                },
                "VkPhysicalDeviceVulkan11Features": {
                    "shaderDrawParameters": true,
                    "variablePointers": true,
                    "variablePointersStorageBuffer": true,
                    "uniformAndStorageBuffer16BitAccess": true,
                    "storageBuffer16BitAccess": true
                },
                "VkPhysicalDeviceVulkan12Features": {
                    "vulkanMemoryModel": true,
                    "bufferDeviceAddress": true,
                    "runtimeDescriptorArray": true,
                    "descriptorIndexing": true,
                    "shaderSampledImageArrayNonUniformIndexing": true,
                    "descriptorBindingSampledImageUpdateAfterBind": true,
                    "shaderStorageImageArrayNonUniformIndexing": true,
                    "descriptorBindingStorageImageUpdateAfterBind": true,
                    "shaderStorageBufferArrayNonUniformIndexing": true,
                    "descriptorBindingStorageBufferUpdateAfterBind": true,
                    "shaderUniformBufferArrayNonUniformIndexing": true,
                    "descriptorBindingUniformBufferUpdateAfterBind": true,
                    "shaderInputAttachmentArrayDynamicIndexing": true,
                    "shaderInputAttachmentArrayNonUniformIndexing": true,
                    "descriptorBindingPartiallyBound": true,
                    "descriptorBindingVariableDescriptorCount": true,
                    "descriptorBindingUpdateUnusedWhilePending": true,
                    "shaderFloat16": true,
                    "storageBuffer8BitAccess": true,
                    "uniformAndStorageBuffer8BitAccess": true,
                    "scalarBlockLayout": true,
                    "shaderInt8": true,
                    "timelineSemaphore": true,
                    "uniformBufferStandardLayout": true
                },
                "VkPhysicalDeviceVulkan13Features": {
                    "dynamicRendering": true,
                    "computeFullSubgroups": true,
                    "maintenance4": true,
                    "synchronization2": true
                },
                "VkPhysicalDeviceVulkan14Features": {
                    "shaderFloatControls2": true,
                    "shaderSubgroupRotate": true,
                    "maintenance5": true,
                    "maintenance6": true,
                    "dynamicRenderingLocalRead": true
                },
                "VkPhysicalDeviceMaintenance7FeaturesKHR": {
                    "maintenance7": true
                },
                "VkPhysicalDeviceMaintenance8FeaturesKHR": {
                    "maintenance8": true
                },
                "VkPhysicalDeviceMaintenance9FeaturesKHR": {
                    "maintenance9": true
                },
                "VkPhysicalDevicePipelineBinaryFeaturesKHR": {
                    "pipelineBinaries": true
                },
                "VkPhysicalDeviceShaderMaximalReconvergenceFeaturesKHR": {
                    "shaderMaximalReconvergence": true
                },
                "VkPhysicalDeviceDeviceGeneratedCommandsFeaturesEXT": {
                    "deviceGeneratedCommands": true
                }
            },
            "properties": {
                "VkPhysicalDeviceVulkan11Properties": {
                    "subgroupSupportedStages": ["VK_SHADER_STAGE_COMPUTE_BIT"],
                    "subgroupSize": 2,
                    "subgroupSupportedOperations": [
                        "VK_SUBGROUP_FEATURE_BASIC_BIT",
                        "VK_SUBGROUP_FEATURE_ARITHMETIC_BIT",
                        "VK_SUBGROUP_FEATURE_VOTE_BIT",
                        "VK_SUBGROUP_FEATURE_BALLOT_BIT",
                        "VK_SUBGROUP_FEATURE_ROTATE_BIT",
                        "VK_SUBGROUP_FEATURE_SHUFFLE_BIT",
                        "VK_SUBGROUP_FEATURE_SHUFFLE_RELATIVE_BIT"
                    ]
                },
                "VkPhysicalDeviceVulkan14Properties": {
                    "dynamicRenderingLocalReadDepthStencilAttachments": true
                },
                "VkPhysicalDeviceDeviceGeneratedCommandsPropertiesEXT": {
                    "supportedIndirectCommandsShaderStagesPipelineBinding": [
                        "VK_SHADER_STAGE_COMPUTE_BIT"
                    ]
                }
            }
        },
        "mesh_shaders": {
            "extensions": {
                "VK_EXT_mesh_shader": 1
            }
        },
        "mesh_shaders_dgc": {
            "properties": {
                "VkPhysicalDeviceDeviceGeneratedCommandsPropertiesEXT": {
                    "supportedIndirectCommandsShaderStagesPipelineBinding": [
                        "VK_SHADER_STAGE_MESH_BIT_EXT"
                    ]
                }
            }
        },
        "display_base": {
            "extensions": {
                "VK_KHR_surface": 1,
                "VK_KHR_swapchain": 1
            }
        },
        "present_timing": {
            "extensions": {
                "VK_KHR_present_id2": 1,
                "VK_KHR_present_wait2": 1
            }
        },
        "surface_maintenance_ext": {
            "extensions": {
                "VK_EXT_surface_maintenance1": 1
            }
        },
        "surface_maintenance_khr": {
            "extensions": {
                "VK_KHR_surface_maintenance1": 1
            }
        },
        "swapchain_maintenance_ext": {
            "extensions": {
                "VK_EXT_swapchain_maintenance1": 1
            }
        },
        "swapchain_maintenance_khr": {
            "extensions": {
                "VK_KHR_swapchain_maintenance1": 1
            }
        },
        "fifo_latest_ready": {
            "extensions": {
                "VK_KHR_present_mode_fifo_latest_ready": 1
            }
        },
        "hdr": {
            "extensions": {
                "VK_EXT_hdr_metadata": 1
            }
        },
        "colorspace": {
            "extensions": {
                "VK_EXT_swapchain_colorspace": 1
            }
        }
    },
    "profiles": {
        "VP_RSL_min": {
            "version": 1,
            "api-version": "1.4.0",
            "label": "RSL Minimum Requirements",
            "description": "Minimum required Vulkan capabilities for running RSL programs",
            "capabilities": [
                "base"
            ],
            "optionals": [
                "mesh_shaders",
                "mesh_shaders_dgc",
                "display_base",
                "present_timing",
                "surface_maintenance_ext",
                "surface_maintenance_khr",
                "swapchain_maintenance_ext",
                "swapchain_maintenance_khr",
                "fifo_latest_ready",
                "hdr",
                "colorspace"
            ]
        }
    }
}
